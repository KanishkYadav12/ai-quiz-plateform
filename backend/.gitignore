# =========================
# Node.js Backend .gitignore
# =========================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment Variables
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
*.env

# Build Output
dist/
build/
out/

# Logs
logs/
*.log
combined.log
error.log

# Runtime & Process
pids/
*.pid
*.seed
*.pid.lock

# Coverage & Testing
coverage/
.nyc_output/
*.lcov
test-results/
junit.xml

# Cache
.npm
.eslintcache
.node_repl_history
.cache/

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor & IDE
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.user
.history/

# Uploads & Static Files (if stored locally)
uploads/
public/uploads/
tmp/
temp/

# Database
*.sqlite
*.sqlite3
*.db

# SSL / Certificates
*.pem
*.key
*.crt
*.p12

# Docker (local overrides)
docker-compose.override.yml

# Miscellaneous
*.tgz
*.tar.gz